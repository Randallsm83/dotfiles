{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
# Sync Claude Code project memories by junctioning platform-encoded
# project paths directly to chezmoi source. New memories written by
# Claude Code land in the source repo, visible in git diff immediately.

$ErrorActionPreference = 'Stop'

$SourceMemories = "{{ .chezmoi.sourceDir }}\dot_claude\project-memories"
$ProjectsDir = "{{ .chezmoi.homeDir }}\.claude\projects"

function Get-EncodedPath {
    param([string]$FullPath)
    $FullPath -replace '[:\\/]', '-'
}

{{ range $name, $relpath := .claude_memory_projects -}}
# Project: {{ $name }} -> {{ $relpath }}
$FullPath = "{{ $.chezmoi.homeDir }}\{{ $relpath | replace "/" "\\" }}"
$Encoded = Get-EncodedPath $FullPath
$TargetDir = "$ProjectsDir\$Encoded"
$MemoryLink = "$TargetDir\memory"
$SourceDir = "$SourceMemories\{{ $name }}"

if (Test-Path $SourceDir) {
    if (-not (Test-Path $TargetDir)) {
        New-Item -ItemType Directory -Path $TargetDir -Force | Out-Null
    }

    if (Test-Path $MemoryLink) {
        $item = Get-Item $MemoryLink -Force
        if ($item.LinkType -eq 'SymbolicLink' -or $item.LinkType -eq 'Junction') {
            $currentTarget = $item.Target
            if ($currentTarget -ne $SourceDir) {
                Remove-Item $MemoryLink -Force -Recurse
                New-Item -ItemType Junction -Path $MemoryLink -Target $SourceDir | Out-Null
            }
        } else {
            # Real directory — back it up and replace
            $backup = "$MemoryLink.bak.$(Get-Date -Format 'yyyyMMddHHmmss')"
            Move-Item $MemoryLink $backup
            New-Item -ItemType Junction -Path $MemoryLink -Target $SourceDir | Out-Null
        }
    } else {
        New-Item -ItemType Junction -Path $MemoryLink -Target $SourceDir | Out-Null
    }
}

{{ end -}}
{{- end }}
