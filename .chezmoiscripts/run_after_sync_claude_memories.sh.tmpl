{{- if ne .chezmoi.os "windows" -}}
#!/bin/bash
# Sync Claude Code project memories by symlinking platform-encoded
# project paths directly to chezmoi source. New memories written by
# Claude Code land in the source repo, visible in git diff immediately.

set -euo pipefail

SOURCE_MEMORIES="{{ .chezmoi.sourceDir }}/dot_claude/project-memories"
PROJECTS_DIR="{{ .chezmoi.homeDir }}/.claude/projects"

# Encode a full path the way Claude Code does: replace / with -
# and strip the leading dash
encode_path() {
    echo "$1" | sed 's|/|-|g' | sed 's|^-||'
}

{{ range $name, $relpath := .claude_memory_projects -}}
# Project: {{ $name }} -> {{ $relpath }}
FULL_PATH="{{ $.chezmoi.homeDir }}/{{ $relpath }}"
ENCODED=$(encode_path "$FULL_PATH")
TARGET_DIR="$PROJECTS_DIR/$ENCODED"
MEMORY_LINK="$TARGET_DIR/memory"
SOURCE_DIR="$SOURCE_MEMORIES/{{ $name }}"

if [ -d "$SOURCE_DIR" ]; then
    mkdir -p "$TARGET_DIR"
    if [ -L "$MEMORY_LINK" ]; then
        CURRENT_TARGET=$(readlink "$MEMORY_LINK")
        if [ "$CURRENT_TARGET" != "$SOURCE_DIR" ]; then
            rm "$MEMORY_LINK"
            ln -s "$SOURCE_DIR" "$MEMORY_LINK"
        fi
    elif [ -d "$MEMORY_LINK" ]; then
        mv "$MEMORY_LINK" "$MEMORY_LINK.bak.$(date +%s)"
        ln -s "$SOURCE_DIR" "$MEMORY_LINK"
    else
        ln -s "$SOURCE_DIR" "$MEMORY_LINK"
    fi
fi

{{ end -}}
{{- end }}
