{{- /* Scoop package list based on feature flags */ -}}
[
{{- range .always_install.scoop }}
    "{{ . }}",
{{- end }}
{{- range $feature, $enabled := .package_features }}
  {{- if $enabled }}
    {{- if hasKey $.package_mapping $feature }}
      {{- $mapping := index $.package_mapping $feature }}
      {{- if hasKey $mapping "windows" }}
        {{- $win := index $mapping "windows" }}
        {{- if hasKey $win "scoop" }}
          {{- range index $win "scoop" }}
    "{{ . }}",
          {{- end }}
        {{- end }}
      {{- end }}
    {{- end }}
  {{- end }}
{{- end }}
    "__end__"
]
