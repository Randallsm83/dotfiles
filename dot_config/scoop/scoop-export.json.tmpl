{{- /* Generate a scoop-import-compatible JSON from chezmoidata feature flags.
       Run `scoop import ~/.config/scoop/scoop-export.json` to restore.
       This file is auto-generated by chezmoi — edit .chezmoidata.yaml instead. */ -}}
{{- if eq .chezmoi.os "windows" -}}
{{- /* Build a reverse lookup: app name → bucket name */ -}}
{{- $bucketLookup := dict -}}
{{- range $bucket, $apps := .scoop_bucket_overrides -}}
  {{- range $apps -}}
    {{- $bucketLookup = set $bucketLookup . $bucket -}}
  {{- end -}}
{{- end -}}
{{- /* Collect all scoop apps from always_install + enabled features */ -}}
{{- $allApps := list -}}
{{- range .always_install.scoop -}}
  {{- $allApps = append $allApps . -}}
{{- end -}}
{{- range $feature, $enabled := .package_features -}}
  {{- if $enabled -}}
    {{- if hasKey $.package_mapping $feature -}}
      {{- $mapping := index $.package_mapping $feature -}}
      {{- if hasKey $mapping "windows" -}}
        {{- $win := index $mapping "windows" -}}
        {{- if hasKey $win "scoop" -}}
          {{- range $win.scoop -}}
            {{- $allApps = append $allApps . -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $allApps = $allApps | uniq | sortAlpha -}}
{
    "apps": [
{{- range $i, $app := $allApps }}
        {
            "Name": "{{ $app }}",
            "Source": "{{ if hasKey $bucketLookup $app }}{{ index $bucketLookup $app }}{{ else }}main{{ end }}"
        }{{ if not (eq $i (sub (len $allApps) 1)) }},{{ end }}
{{- end }}
    ],
    "buckets": [
        {
            "Name": "main",
            "Source": "https://github.com/ScoopInstaller/Main"
        },
{{- $bucketList := keys .scoop_buckets | sortAlpha -}}
{{- range $i, $name := $bucketList }}
        {
            "Name": "{{ $name }}",
            "Source": "{{ index $.scoop_buckets $name }}"
        }{{ if not (eq $i (sub (len $bucketList) 1)) }},{{ end }}
{{- end }}
    ]
}
{{- end -}}
