{{- /* Generate a winget-import-compatible JSON from chezmoidata feature flags.
       Run `winget import ~/.config/winget/winget-export.json` to restore.
       This file is auto-generated by chezmoi — edit .chezmoidata.yaml instead. */ -}}
{{- if eq .chezmoi.os "windows" -}}
{{- $allPkgs := list -}}
{{- range .always_install.winget -}}
  {{- $allPkgs = append $allPkgs . -}}
{{- end -}}
{{- range $feature, $enabled := .package_features -}}
  {{- if $enabled -}}
    {{- if hasKey $.package_mapping $feature -}}
      {{- $mapping := index $.package_mapping $feature -}}
      {{- if hasKey $mapping "windows" -}}
        {{- $win := index $mapping "windows" -}}
        {{- if hasKey $win "winget" -}}
          {{- range $win.winget -}}
            {{- $allPkgs = append $allPkgs . -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $allPkgs = $allPkgs | uniq | sortAlpha -}}
{
    "$schema": "https://aka.ms/winget-packages.schema.2.0.json",
    "Sources": [
        {
            "Packages": [
{{- range $i, $pkg := $allPkgs }}
                {
                    "PackageIdentifier": "{{ $pkg }}"
                }{{ if not (eq $i (sub (len $allPkgs) 1)) }},{{ end }}
{{- end }}
            ],
            "SourceDetails": {
                "Argument": "https://cdn.winget.microsoft.com/cache",
                "Identifier": "Microsoft.Winget.Source_8wekyb3d8bbwe",
                "Name": "winget",
                "Type": "Microsoft.PreIndexed.Package"
            }
        }
    ]
}
{{- end -}}
